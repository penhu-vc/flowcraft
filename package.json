{
  "name": "flowcraft",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host 0.0.0.0\" \"npm run server\"",
    "server": "cd server && npm run dev",
    "dev:client": "vite --host 0.0.0.0",
    "dev:up": "node scripts/dev-up.mjs",
    "dev:warm": "node scripts/dev-warm.mjs",
    "dev:doctor": "node scripts/dev-doctor.mjs",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "auth:notebooklm": "cd server && npm run auth:notebooklm"
  },
  "dependencies": {
    "@types/dagre": "^0.7.54",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@vueuse/core": "^14.2.1",
    "dagre": "^0.8.5",
    "lucide-vue-next": "^0.575.0",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.1.5"
  }
}
