# FlowCraft 環境變數範例
# 複製此檔案為 .env.local 並填入真實值

# GCP 憑證路徑（本地開發用）
GOOGLE_APPLICATION_CREDENTIALS=./server/gcp-credentials.json

# Google Sheets API
# GOOGLE_SHEET_ID=你的試算表ID

# Telegram Bot（選用）
# TELEGRAM_BOT_TOKEN=你的Bot Token
# TELEGRAM_CHAT_ID=你的Chat ID

# 其他 API Keys
# GEMINI_API_KEY=你的Gemini API Key
