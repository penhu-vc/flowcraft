{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "8080"],
      "port": 8080,
      "autoPort": true
    },
    {
      "name": "backend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/ts-node-dev/lib/bin.js", "--respawn", "--transpile-only", "src/index.ts"],
      "cwd": "server",
      "port": 3001,
      "autoPort": true
    }
  ]
}
