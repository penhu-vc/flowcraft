# Flowcraft Server 環境變數範本
# 複製此檔案為 .env 並填入實際值

# ========================================
# Telegram Bot 設定
# ========================================

# Telegram Bot Token (從 @BotFather 取得)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 點擊標籤按鈕時的回應訊息前綴
TELEGRAM_CLICK_RESPONSE=你點擊了標籤：

# ========================================
# 伺服器設定
# ========================================

# 後端伺服器端口（預設 3001）
PORT=3001
